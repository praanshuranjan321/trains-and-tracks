        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (mode)(rate(tg_chaos_triggered_total{env=\"$env\"}[1m]))",
          "legendFormat": "chaos {{mode}}",
          "refId": "B"
        }
