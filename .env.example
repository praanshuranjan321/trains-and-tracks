# === DATABASE (Supabase) ===
# Runtime: use TRANSACTION pooler (port 6543) — REQUIRED for serverless
# User format is postgres.<PROJECT_REF>, host is aws-1-<region>.pooler.supabase.com
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migrations only (direct, port 5432) — IPv6-only on Supabase free tier; CLI (HTTPS) preferred
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres"

# Supabase JS client (PostgREST via HTTPS — works on Edge)
SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Supabase Management API (used for deploys / config queries only)
SUPABASE_ACCESS_TOKEN="sbp_..."

# === QUEUE (Upstash QStash) ===
QSTASH_TOKEN="..."
QSTASH_CURRENT_SIGNING_KEY="..."
QSTASH_NEXT_SIGNING_KEY="..."
QSTASH_URL="https://qstash.upstash.io"

# === CACHE (Upstash Redis) ===
UPSTASH_REDIS_REST_URL="https://<id>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# === METRICS (Grafana Cloud Mimir) ===
GRAFANA_PROM_URL="https://prometheus-prod-<N>-prod-<region>-0.grafana.net/api/prom/push"
GRAFANA_PROM_USER="<numeric-instance-id>"
GRAFANA_PROM_TOKEN="glc_..."

# === Grafana HTTP API (for Recharts proxy) ===
GRAFANA_PROM_READ_URL="https://prometheus-prod-<N>-prod-<region>-0.grafana.net/api/prom"
GRAFANA_PROM_READ_TOKEN="glc_..."

# === DEPLOY (local CLI use only) ===
GITHUB_TOKEN="ghp_..."
VERCEL_TOKEN="vcp_..."

# === ADMIN ===
# Generate via: openssl rand -hex 32
ADMIN_SECRET=""

# === APP ===
APP_URL="https://<your-deployment>.vercel.app"
PAYMENT_FAILURE_RATE="0.05"  # 5% — clean demo visuals; retry/DLQ story carried by Kill Worker button instead. Crank to 0.30 for a dedicated gateway-flake stress test (I1/I2 invariants hold at any rate).
HOLD_DURATION_SEC="300"       # 5 min in prod; reduce to 10 for hold-expiration demo

# === DEV-ONLY ===
# Bypass QStash signature verification locally so we can curl sweeper/worker/
# failure-callback routes directly. NEVER set in production; the verifier
# refuses to honor the flag when NODE_ENV=production anyway.
QSTASH_DEV_BYPASS="0"

# === FRONTEND (exposed to browser — never put secrets here) ===
# Public Shared Dashboard URL from Grafana Cloud (Dashboard → Share → Public URL).
# /ops embeds this as an iframe; the Recharts hero is driven by /api/insights
# so this is purely supplementary.
NEXT_PUBLIC_GRAFANA_DASHBOARD_URL=""
